{
    "name": "ruudk/graphql-client-code-generator",
    "description": "GraphQL client code generator for PHP",
    "type": "library",
    "require": {
        "php": "^8.4",
        "doctrine/inflector": "^2.0",
        "ruudk/code-generator": "^0.1.6",
        "symfony/filesystem": "^7.3",
        "symfony/finder": "^7.3",
        "symfony/polyfill-php85": "1.x-dev",
        "symfony/string": "^7.3",
        "symfony/type-info": "^7.3",
        "webmozart/assert": "^1.11",
        "webonyx/graphql-php": "^15.0"
    },
    "require-dev": {
        "captainhook/captainhook-phar": "^5.25",
        "ergebnis/composer-normalize": "^2.47",
        "friendsofphp/php-cs-fixer": "^3.85",
        "php-http/discovery": "^1.20",
        "php-http/guzzle7-adapter": "^1.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "symfony/dotenv": "^7.3",
        "symfony/var-dumper": "^7.3",
        "ticketswap/php-cs-fixer-config": "^1.0",
        "ticketswap/phpstan-error-formatter": "^1.1",
        "phpunit/phpunit": "^12.3",
        "php-http/mock-client": "^1.6",
        "staabm/phpstan-todo-by": "^0.3.0"
    },
    "autoload": {
        "psr-4": {
            "Ruudk\\GraphQLCodeGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ruudk\\GraphQLCodeGenerator\\Examples\\": "examples/",
            "Ruudk\\GraphQLCodeGenerator\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "captainhook/captainhook-phar": true,
            "ergebnis/composer-normalize": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
